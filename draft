import pandas as pd
import streamlit as st

st.set_page_config(
    page_title="Career Transition Assistant",
    page_icon="🧭",
    layout="wide",
)

st.title("🧭 Career Transition Guide")

def normalize_proficiency(value):
    """Use the raw proficiency level when possible, without mapping text labels."""
    if pd.isna(value):
        return 1

    value_str = str(value).strip()
    if value_str.isdigit():
        return max(1, min(6, int(value_str)))

    try:
        return max(1, min(6, int(float(value_str))))
    except (TypeError, ValueError):
        return 1


def split_skills(value):
    return [item.strip() for item in str(value).split(",") if item.strip()]


def build_course_recommendation(skill):
    skill_lower = skill.lower()
    if any(keyword in skill_lower for keyword in ["safety", "emergency", "incident"]):
        return f"{skill} Safety & Response Training"
    if any(keyword in skill_lower for keyword in ["service", "customer", "hospitality"]):
        return f"{skill} Customer Service Workshop"
    if any(keyword in skill_lower for keyword in ["lead", "management", "planning", "coordination"]):
        return f"{skill} Leadership & Management Course"
    if any(keyword in skill_lower for keyword in ["data", "technology", "digital", "analytics"]):
        return f"{skill} Digital Skills Program"
    return f"{skill} Skills Development Course"


@st.cache_data
def load_job_skill_data():
    df = pd.read_csv("job-skill.csv")
    required_columns = {"JobRole", "SkillList", "Proficiency Level"}
    if not required_columns.issubset(df.columns):
        st.error(
            f"The CSV must contain these columns: {sorted(required_columns)}"
        )
        st.stop()

    skill_df = df[["JobRole", "SkillList", "Proficiency Level"]].copy()
    skill_df["JobRole"] = skill_df["JobRole"].fillna("").astype(str).str.strip()
    skill_df["SkillList"] = (
        skill_df["SkillList"].fillna("").astype(str).str.strip()
    )
    skill_df = skill_df[
        (skill_df["JobRole"] != "") & (skill_df["SkillList"] != "")
    ]

    job_to_skills = {}
    for job_name, group in skill_df.groupby("JobRole", sort=False):
        best_scores = {}
        for _, row in group.iterrows():
            skill_score = normalize_proficiency(row["Proficiency Level"])
            for skill in split_skills(row["SkillList"]):
                best_scores[skill] = max(best_scores.get(skill, 0), skill_score)

        job_to_skills[job_name] = sorted(
            (
                {
                    "skill": skill,
                    "importance": round((score / 6) * 10, 1),
                }
                for skill, score in best_scores.items()
            ),
            key=lambda item: (-item["importance"], item["skill"]),
        )

    return job_to_skills


job_to_skills = load_job_skill_data()
job_options = list(job_to_skills.keys())

if not job_options:
    st.error("No valid job-role data was found in the CSV.")
    st.stop()

with st.form("transition_form"):
    current_job = st.selectbox(
        "Current job",
        job_options,
        help="Choose your current role from the dataset.",
    )
    target_job = st.selectbox(
        "Job you want to transition to",
        job_options,
        help="Choose the role you want to move toward.",
    )
    submitted = st.form_submit_button("Show recommendation")

if submitted:
    st.session_state["submitted"] = True
    st.session_state["target_job"] = target_job
    st.session_state["current_job"] = current_job

if st.session_state.get("submitted", False):
    target_job = st.session_state.get("target_job", job_options[0])
    current_job = st.session_state.get("current_job", job_options[0])
    target_skills = job_to_skills.get(target_job, [])

    st.success(f"Recommended path from {current_job} to {target_job}")

    st.subheader(f"Skills needed for {target_job}")
    if target_skills:
        st.caption(
            "Select the skills you want to focus on, then press Next to see course recommendations."
        )

        for skill_info in target_skills:
            skill = skill_info["skill"]
            importance = skill_info["importance"]
            key = f"selected_skill::{target_job}::{skill}"
            col1, col2 = st.columns([0.75, 0.25])
            with col1:
                st.checkbox(
                    skill,
                    value=st.session_state.get(key, False),
                    key=key,
                )
            with col2:
                st.caption(f"Importance: {importance:.1f}/10")

        if st.button("Next"):
            selected_skill_names = [
                skill_info["skill"]
                for skill_info in target_skills
                if st.session_state.get(
                    f"selected_skill::{target_job}::{skill_info['skill']}",
                    False,
                )
            ]

            if selected_skill_names:
                st.subheader("Suggested courses")
                for skill in selected_skill_names:
                    st.markdown(
                        f"- **{skill}** — {build_course_recommendation(skill)}"
                    )
            else:
                st.info("Please select at least one skill before continuing.")
    else:
        st.info("No skills were found for this role in the dataset.")
