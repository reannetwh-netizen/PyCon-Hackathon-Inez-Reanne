@st.cache_resource
def get_openai_client(api_key: str) -> OpenAI:
    return OpenAI(api_key=api_key)


def generate_course_explanation(
    client: OpenAI,
    current_job: str,
    target_job: str,
    missing_skills: list,
    course_title: str,
    course_about: str,
    course_learn: str,
) -> str:
    prompt = f"""You are a career transition advisor. Given the user's profile and a course, provide a concise explanation (3-4 sentences max).

User Profile:
- Current job: {current_job}
- Target job: {target_job}
- Skills to acquire: {', '.join(missing_skills)}

Course Information:
- Title: {course_title}
- Description: {course_about}
- What you'll learn: {course_learn}

Provide a brief explanation covering:
1. How this course helps the career transition
2. Which missing skills it addresses
3. Any potential limitations

Keep it concise and practical."""

    try:
        response = client.chat.completions.create(
            model="gpt-4o-mini",
            max_tokens=300,
            messages=[{"role": "user", "content": prompt}],
        )
        return response.choices[0].message.content
    except Exception as e:
        return f"Could not generate explanation: {str(e)}"


